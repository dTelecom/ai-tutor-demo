# x402 gateway (dTelecom STT/TTS + WebRTC fallback)
WALLET_PRIVATE_KEY=
GATEWAY_URL=https://x402.dtelecom.org

# dTelecom WebRTC credentials (optional — if set, used instead of x402 for WebRTC)
API_KEY=
API_SECRET=

# Provider API keys
DEEPGRAM_API_KEY=
OPENROUTER_API_KEY=
CARTESIA_API_KEY=

# STT provider: 'deepgram' (default) or 'dtelecom'
STT_PROVIDER=deepgram

# TTS provider: 'deepgram' (default) or 'cartesia' or 'dtelecom'
TTS_PROVIDER=deepgram

# Optional overrides
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
LLM_MODEL=openai/gpt-4o-mini

# Memory (SQLite path — mount a persistent volume here in Docker)
# MEMORY_DB_PATH=./data/memory.db
